# DocPilot Server - Umgebungsvariablen
# Kopiere diese Datei nach .env und trage Werte ein

# OpenRouter API Key (KI-Funktionen)
OPENROUTER_API_KEY=dein_key_hier

# KI-Modell (optional, default: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Ports (Railway setzt PORT automatisch)
PORT=8080
OCR_PORT=8080
