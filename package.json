{
  "name": "docpilot-knipexilino-integrated-v3",
  "version": "0.3.0",
  "private": true,
  "description": "DocPilot/Knipexilino integrated static app shell with local document analysis, cases, organizations, OCR and speech hooks.",
  "scripts": {
    "start": "python3 -m http.server 8080",
    "cap:init": "npx cap init DocPilot com.docpilot.knipexilino --web-dir .",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "cap:open:android": "npx cap open android"
  },
  "devDependencies": {
    "@capacitor/android": "latest",
    "@capacitor/cli": "latest",
    "@capacitor/core": "latest"
  }
}
